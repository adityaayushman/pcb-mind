ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Use Supabase's session-mode pooler (port 5432), not the direct db.<ref>.supabase.co
# host (IPv6-only, often unreachable) and not the transaction-mode pooler on 6543
# (asyncpg's prepared statements can collide across pooled backends in that mode).
# Find this under Connect -> "Session pooler" in the Supabase dashboard. URL-encode
# any special characters in the password (e.g. @ -> %40, # -> %23).
DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres

STORAGE_BUCKET=pcb-images
MODEL_WEIGHTS_PATH=app/services/weights/pcb_defect_yolo.pt
INFERENCE_CONFIDENCE_THRESHOLD=0.35
MAX_UPLOAD_MB=10

ALLOWED_ORIGINS=["http://localhost:3000"]
